# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@host:port/database?pgbouncer=true&connection_limit=1"
AUTH_DATABASE_URL="postgresql://username:password@host:port/database"  # Opcional, misma URL si el rol evita RLS
DATABASE_CA_CERT="/path/to/ca-certificate.crt"

# ── Auth / JWT ──────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key"
LICENSE_JWT_SECRET="your-license-jwt-secret"  # Diferente a JWT_SECRET, para códigos de licencia

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:5173"
NODE_ENV=development

# ── Admin default credentials (used on first setup / reset) ────────────
ADMIN_EMAIL=admin@stockmaster.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME="Administrador"
ADMIN_TENANT="StockMaster PRO"

# ── Stripe (subscriptions / payments) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ── Exchange rate API ───────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
