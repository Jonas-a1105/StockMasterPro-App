# ── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string (with PgBouncer for Supabase)
DATABASE_URL="postgresql://username:password@host:port/database?pgbouncer=true&connection_limit=1"
# Direct connection for migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://username:password@host:port/database?sslmode=require"
# SSL CA certificate path (required in production, optional in dev/local)
DATABASE_CA_CERT="/path/to/ca-certificate.crt"

# ── Auth / JWT ──────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:5173"
NODE_ENV=development

# ── Admin default credentials (used on first setup) ─────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ── Stripe (subscriptions / payments) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ── Exchange rate API ───────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
