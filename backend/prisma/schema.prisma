generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  stripeCustomerId   String?  @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String? @map("stripe_subscription_id") @db.VarChar(255)
  planType           String   @default("free") @map("plan_type") @db.VarChar(50)
  subscriptionStatus String   @default("trialing") @map("subscription_status") @db.VarChar(50)
  licenseExpiresAt   DateTime @map("license_expires_at") @db.Timestamptz
  isBlocked          Boolean  @default(false) @map("is_blocked")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users          User[]
  products       Product[]
  sales          Sale[]
  categories     Category[]
  suppliers      Supplier[]
  customers      Customer[]
  purchaseOrders PurchaseOrder[]
  accountsPayable AccountsPayable[]
  payablePayments PayablePayment[]
  expenses        Expense[]
  creditNotes     CreditNote[]
  warehouses      Warehouse[]
  events          CalendarEvent[]
  socialProfiles  SocialProfile[]
  socialPosts     SocialPost[]
  socialCatalogs  SocialCatalog[]
  socialCatalogItems SocialCatalogItem[]
  socialComments  SocialComment[]
  socialReactions SocialReaction[]
  socialFollowers SocialFollow[]
  socialNotifications SocialNotification[]
  socialThreads   SocialThread[]
  socialMessages  SocialMessage[]
  
  accountsReceivable AccountsReceivable[]
  receivablePayments ReceivablePayment[]
  cashSessions       CashSession[]
  refreshTokens      RefreshToken[]
  settings           TenantSettings?
  exchangeRates      ExchangeRate[]
  invoiceSequences   InvoiceSequence[]
  taxWithholdings    TaxWithholding[]
  salePayments       SalePayment[]
inventoryCounts    InventoryCount[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  journalEntryLines  JournalEntryLine[]
  fiscalPeriods      FiscalPeriod[]
  accountBalances    AccountBalance[]
  costCenters        CostCenter[]
  projects           Project[]
  taxRates           TaxRate[]
  licenses           License[]

  @@map("tenants")
}

model TenantSettings {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @unique @map("tenant_id") @db.Uuid
  taxRate       Decimal  @default(16) @map("tax_rate") @db.Decimal(5, 2)
  taxName       String   @default("IVA") @map("tax_name") @db.VarChar(50)
  currencySymbol String  @default("Bs") @map("currency_symbol") @db.VarChar(10)
  currencyPosition String @default("before") @map("currency_position") @db.VarChar(10)
  decimalPlaces Int      @default(2) @map("decimal_places")
  displayCurrency String @default("both") @map("display_currency") @db.VarChar(20)
  manualExchangeRate Decimal? @default(0) @map("manual_exchange_rate") @db.Decimal(12, 4)
  ivaWithholdingRate Decimal? @default(75) @map("iva_withholding_rate") @db.Decimal(5, 2)
  islrWithholdingRate Decimal? @default(5) @map("islr_withholding_rate") @db.Decimal(5, 2)
  companyTaxId     String? @map("company_tax_id") @db.VarChar(20)
  companyFiscalAddress String? @map("company_fiscal_address") @db.Text
  companyPhone     String? @map("company_phone") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model ExchangeRate {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  rate      Decimal  @db.Decimal(12, 4)
  source    String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("exchange_rates")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  name           String   @db.VarChar(255)
  role           String   @default("cajero") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  approvedPurchaseOrders    PurchaseOrder[] @relation("ApprovedPurchaseOrders")
  rejectedPurchaseOrders    PurchaseOrder[] @relation("RejectedPurchaseOrders")
  cancelledPurchaseOrders   PurchaseOrder[] @relation("CancelledPurchaseOrders")

  socialProfile        SocialProfile?
  socialPosts          SocialPost[]
  socialCatalogs       SocialCatalog[]
  socialComments       SocialComment[]
  socialReactions      SocialReaction[]
  socialFollowers      SocialFollow[]     @relation("FollowedUsers")
  socialFollowing      SocialFollow[]     @relation("FollowerUsers")
  socialNotifications       SocialNotification[]      @relation("NotificationForUser")
  socialNotificationsFrom   SocialNotification[]      @relation("NotificationFromUser")
  socialSentMessages        SocialMessage[]            @relation("SenderMessages")
  socialThreadMembers       SocialThreadMember[]
  inventoryCounts           InventoryCount[]        @relation("UserInventoryCounts")
  approvedInventoryCounts   InventoryCount[]        @relation("ApprovedInventoryCounts")
  createdJournalEntries     JournalEntry[]          @relation("CreatedJournalEntries")
  postedJournalEntries      JournalEntry[]          @relation("PostedJournalEntries")
  closedFiscalPeriods       FiscalPeriod[]          @relation("ClosedFiscalPeriods")
  managedProjects           Project[]               @relation("ManagedProjects")
  issuedLicenses           License[]               @relation("LicenseIssuedBy")

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("users")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @db.VarChar(50)
  address   String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productWarehouses ProductWarehouse[]
  transfersOut WarehouseTransfer[] @relation("TransferFromWarehouse")
  transfersIn  WarehouseTransfer[] @relation("TransferToWarehouse")
  inventoryCounts InventoryCount[] @relation("WarehouseInventoryCounts")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model ProductWarehouse {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  warehouseId String  @map("warehouse_id") @db.Uuid
  stock      Int      @default(0)
  minStock   Int      @default(0) @map("min_stock")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryCountItems InventoryCountItem[] @relation("ProductWarehouseInventoryCountItems")

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@map("product_warehouses")
}

model WarehouseTransfer {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  fromWarehouseId String      @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String      @map("to_warehouse_id") @db.Uuid
  status         String       @default("pending") @db.VarChar(50)
  notes          String?      @db.Text
  createdBy      String       @map("created_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  completedAt    DateTime?    @map("completed_at")

  fromWarehouse  Warehouse    @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse    Warehouse    @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  items          WarehouseTransferItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("warehouse_transfers")
}

model WarehouseTransferItem {
  id              String   @id @default(uuid()) @db.Uuid
  transferId      String   @map("transfer_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  quantity        Int
  createdAt       DateTime @default(now()) @map("created_at")

  transfer        WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product         Product           @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([productId])
  @@map("warehouse_transfer_items")
}

model ProductLot {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  lotNumber    String   @map("lot_number") @db.VarChar(100)
  quantity     Int      @default(0)
  reservedQty  Int      @default(0) @map("reserved_qty")
  expiryDate   DateTime? @map("expiry_date") @db.Timestamptz
  manufactureDate DateTime? @map("manufacture_date") @db.Timestamptz
  receivedAt   DateTime @default(now()) @map("received_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, lotNumber])
  @@index([tenantId, expiryDate])
  @@index([tenantId, productId, expiryDate])
  @@map("product_lots")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  barcode         String?  @map("codigo_barras") @db.VarChar(100)
  price           Decimal  @db.Decimal(12, 2)
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  stock           Int      @default(0)
  minStock        Int      @default(0) @map("min_stock")
  imageUrl        String?  @map("image_url") @db.Text
  brand           String?  @db.VarChar(255)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productWarehouses ProductWarehouse[]
  lots            ProductLot[]
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  creditNoteItems    CreditNoteItem[]
  warehouseTransferItems WarehouseTransferItem[]
  inventoryCountItems    InventoryCountItem[] @relation("ProductInventoryCountItems")

  @@unique([tenantId, barcode])
  @@index([tenantId, barcode])
  @@index([tenantId, id])
  @@map("products")
}

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String   @db.VarChar(255)
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(50)
  address        String?  @db.Text
  taxId          String?  @map("tax_id") @db.VarChar(20)
  documentType   String?  @default("V") @map("document_type") @db.VarChar(5)
  fiscalAddress  String?  @map("fiscal_address") @db.Text
  creditLimit    Decimal? @default(0) @map("credit_limit") @db.Decimal(12, 2)
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales  Sale[]
  creditNotes CreditNote[]
  accountsReceivable AccountsReceivable[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("customers")
}

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String   @db.VarChar(255)
  contact       String?  @db.VarChar(255)
  phone         String?  @db.VarChar(50)
  email         String?  @db.VarChar(255)
  address       String?  @db.Text
  taxId         String?  @map("tax_id") @db.VarChar(20)
  fiscalAddress String?  @map("fiscal_address") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  accountsPayable AccountsPayable[]
  taxWithholdings TaxWithholding[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("suppliers")
}

model Sale {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  customerId     String?  @map("customer_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  subtotal       Decimal  @db.Decimal(12, 2)
  tax            Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  paymentMethod  String   @default("cash") @map("payment_method") @db.VarChar(50)
  status         String   @default("completed") @db.VarChar(50)
  isOffline      Boolean  @default(false) @map("is_offline")
  offlineId      String?  @map("offline_id") @db.VarChar(255)
  invoiceNumber  String?  @map("invoice_number") @db.VarChar(50)
  invoiceSeries  String?  @default("FACT") @map("invoice_series") @db.VarChar(10)
  documentType   String?  @default("factura") @map("document_type") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       SaleItem[]
  payments    SalePayment[]
  creditNotes CreditNote[]
  accountsReceivable AccountsReceivable[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, invoiceNumber])
  @@index([offlineId])
  @@map("sales")
}

model SalePayment {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  saleId        String   @map("sale_id") @db.Uuid
  paymentMethod String   @map("payment_method") @db.VarChar(50)
  amount        Decimal  @db.Decimal(12, 2)
  amountBs      Decimal? @map("amount_bs") @db.Decimal(12, 2)
  exchangeRate  Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  reference     String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")

  sale     Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
  @@map("sale_payments")
}

model SaleItem {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  saleId    String  @map("sale_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  cost      Decimal @db.Decimal(12, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2) @map("tax_rate")
  taxAmount Decimal @default(0) @db.Decimal(12, 2) @map("tax_amount")
  discount  Decimal @default(0) @db.Decimal(5, 2) @map("discount")
  subtotal  Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([tenantId, id])
  @@map("sale_items")
}

model PurchaseOrder {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  supplierId          String?           @map("supplier_id") @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  status              String            @default("pending") @db.VarChar(50)
  total               Decimal           @default(0) @db.Decimal(12, 2)
  notes               String?           @db.Text
  expectedDeliveryDate DateTime?        @map("expected_delivery_date") @db.Date
  approvedById        String?           @map("approved_by") @db.Uuid
  approvedAt          DateTime?         @map("approved_at")
  rejectedById        String?           @map("rejected_by") @db.Uuid
  rejectedAt          DateTime?         @map("rejected_at")
  rejectionReason     String?           @map("rejection_reason") @db.Text
  cancelledById       String?           @map("cancelled_by") @db.Uuid
  cancelledAt         DateTime?         @map("cancelled_at")
  cancellationReason  String?           @map("cancellation_reason") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  approvedBy      User?               @relation("ApprovedPurchaseOrders", fields: [approvedById], references: [id])
  rejectedBy      User?               @relation("RejectedPurchaseOrders", fields: [rejectedById], references: [id])
  cancelledBy     User?               @relation("CancelledPurchaseOrders", fields: [cancelledById], references: [id])
  items           PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(uuid()) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  purchaseOrderId  String  @map("purchase_order_id") @db.Uuid
  productId        String  @map("product_id") @db.Uuid
  quantity         Int
  receivedQty      Int     @default(0) @map("received_qty")
  cost             Decimal @db.Decimal(12, 2)
  subtotal         Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([tenantId, id])
  @@map("purchase_order_items")
}

model InventoryMovement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  type      String   @db.VarChar(50)
  quantity  Int
  reference String?  @db.VarChar(255)
  notes     String?  @db.Text
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("inventory_movements")
}

model AccountsPayable {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  supplierId      String   @map("supplier_id") @db.Uuid
  purchaseOrderId String?  @map("purchase_order_id") @db.Uuid
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  pendingAmount   Decimal  @map("pending_amount") @db.Decimal(12, 2)
  dueDate         DateTime @map("due_date") @db.Date
  status          String   @default("pending") @db.VarChar(50)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier         @relation(fields: [supplierId], references: [id])
  payments PayablePayment[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@map("accounts_payable")
}

model PayablePayment {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  accountPayableId  String   @map("account_payable_id") @db.Uuid
  amount            Decimal  @db.Decimal(12, 2)
  paymentMethod     String   @default("cash") @map("payment_method") @db.VarChar(50)
  notes             String?  @db.Text
  paidAt            DateTime @map("paid_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at")

  accountPayable AccountsPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountPayableId])
  @@map("payable_payments")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  description   String   @db.VarChar(255)
  amount        Decimal  @db.Decimal(12, 2)
  category      String   @db.VarChar(100)
  paymentMethod String   @default("cash") @map("payment_method") @db.VarChar(50)
  notes         String?  @db.Text
  registeredBy  String   @map("registered_by") @db.Uuid
  expenseDate   DateTime @map("expense_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, expenseDate])
  @@index([tenantId, category])
  @@map("expenses")
}

model CreditNote {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  saleId        String?  @map("sale_id") @db.Uuid
  customerId    String?  @map("customer_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  reason        String   @db.Text
  total         Decimal  @db.Decimal(12, 2)
  status        String   @default("active") @db.VarChar(50)
  refundMethod  String   @default("credit") @map("refund_method") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sale     Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  items    CreditNoteItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("credit_notes")
}

model CreditNoteItem {
  id             String  @id @default(uuid()) @db.Uuid
  creditNoteId   String  @map("credit_note_id") @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  quantity       Int
  price          Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

