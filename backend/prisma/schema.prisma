  closingDebit    Decimal  @default(0) @map("closing_debit") @db.Decimal(12, 2)
  closingCredit   Decimal  @default(0) @map("closing_credit") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountId, fiscalPeriodId])
  @@index([tenantId, fiscalPeriodId])
  @@map("account_balances")
}

model CostCenter {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(20)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      CostCenter?      @relation("CostCenterHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    CostCenter[]     @relation("CostCenterHierarchy")
  journalLines JournalEntryLine[] @relation("CostCenterJournalLines")

  @@unique([tenantId, code])
  @@index([tenantId, parentId])
  @@map("cost_centers")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(20)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  status      String   @default("active") @db.VarChar(20)
  budget      Decimal? @db.Decimal(12, 2)
  managerId   String?  @map("manager_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager      User?               @relation("ManagedProjects", fields: [managerId], references: [id])
  journalLines JournalEntryLine[]  @relation("ProjectJournalLines")

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("projects")
}

model TaxRate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  rate        Decimal  @db.Decimal(5, 2)
  type        String   @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  validFrom   DateTime @map("valid_from") @db.Date
  validTo     DateTime? @map("valid_to") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

@@index([tenantId, type, isActive])
@@map("tax_rates")
}

model InventoryCount {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  warehouseId  String?  @map("warehouse_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  status       String   @default("draft") @db.VarChar(20) // draft, in_progress, completed, approved, cancelled
  name         String?  @db.VarChar(255)
  notes        String?  @db.Text
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  approvedBy   String?  @map("approved_by") @db.Uuid
  approvedAt   DateTime? @map("approved_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse  Warehouse? @relation("WarehouseInventoryCounts", fields: [warehouseId], references: [id], onDelete: SetNull)
  user       User       @relation("UserInventoryCounts", fields: [userId], references: [id])
  approver   User?      @relation("ApprovedInventoryCounts", fields: [approvedBy], references: [id])
  items      InventoryCountItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("inventory_counts")
}

model InventoryCountItem {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  inventoryCountId   String   @map("inventory_count_id") @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  productWarehouseId String?  @map("product_warehouse_id") @db.Uuid
  systemQty          Int      @map("system_qty")
  countedQty         Int?     @map("counted_qty")
  difference         Int      @default(0)
  notes              String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  inventoryCount   InventoryCount    @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  product          Product           @relation("ProductInventoryCountItems", fields: [productId], references: [id])
  productWarehouse ProductWarehouse? @relation("ProductWarehouseInventoryCountItems", fields: [productWarehouseId], references: [id], onDelete: SetNull)

  @@index([inventoryCountId])
  @@index([tenantId, productId])
  @@map("inventory_count_items")
}

model License {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  jti             String   @unique @db.VarChar(255)
  tier            String   @db.VarChar(50)
  issuedAt        DateTime @default(now()) @map("issued_at")
  expiresAt       DateTime @map("expires_at")
  activatedAt     DateTime? @map("activated_at")
  status          String   @default("issued") @db.VarChar(20) // issued, activated, revoked, expired
  issuedBy        String?  @map("issued_by") @db.Uuid
  revokedAt       DateTime? @map("revoked_at")
  revokedBy       String?  @map("revoked_by") @db.Uuid
  revokedReason   String?  @map("revoked_reason") @db.Text
  payload         Json     @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issuer     User?      @relation("LicenseIssuedBy", fields: [issuedBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([jti])
  @@index([status])
  @@index([expiresAt])
  @@map("licenses")
}

