generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  stripeCustomerId   String?  @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String? @map("stripe_subscription_id") @db.VarChar(255)
  planType           String   @default("free") @map("plan_type") @db.VarChar(50)
  subscriptionStatus String   @default("trialing") @map("subscription_status") @db.VarChar(50)
  licenseExpiresAt   DateTime @map("license_expires_at") @db.Timestamptz
  isBlocked          Boolean  @default(false) @map("is_blocked")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users          User[]
  products       Product[]
  sales          Sale[]
  categories     Category[]
  suppliers      Supplier[]
  customers      Customer[]
  purchaseOrders PurchaseOrder[]
  accountsPayable AccountsPayable[]
  payablePayments PayablePayment[]
  expenses        Expense[]
  creditNotes     CreditNote[]
  warehouses      Warehouse[]
  events          CalendarEvent[]
  socialProfiles  SocialProfile[]
  socialPosts     SocialPost[]
  socialCatalogs  SocialCatalog[]
  socialCatalogItems SocialCatalogItem[]
  socialComments  SocialComment[]
  socialReactions SocialReaction[]
  socialFollowers SocialFollow[]
  socialNotifications SocialNotification[]
  socialThreads   SocialThread[]
  socialMessages  SocialMessage[]
  
  accountsReceivable AccountsReceivable[]
  receivablePayments ReceivablePayment[]
  cashSessions       CashSession[]
  refreshTokens      RefreshToken[]

  @@map("tenants")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  name           String   @db.VarChar(255)
  role           String   @default("cajero") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  socialProfile        SocialProfile?
  socialPosts          SocialPost[]
  socialCatalogs       SocialCatalog[]
  socialComments       SocialComment[]
  socialReactions      SocialReaction[]
  socialFollowers      SocialFollow[]     @relation("FollowedUsers")
  socialFollowing      SocialFollow[]     @relation("FollowerUsers")
  socialNotifications       SocialNotification[]      @relation("NotificationForUser")
  socialNotificationsFrom   SocialNotification[]      @relation("NotificationFromUser")
  socialSentMessages        SocialMessage[]            @relation("SenderMessages")
  socialThreadMembers       SocialThreadMember[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("users")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @db.VarChar(50)
  address   String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  barcode         String?  @map("codigo_barras") @db.VarChar(100)
  price           Decimal  @db.Decimal(12, 2)
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  stock           Int      @default(0)
  minStock        Int      @default(0) @map("min_stock")
  imageUrl        String?  @map("image_url") @db.Text
  brand           String?  @db.VarChar(255)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  warehouseId     String?            @map("warehouse_id") @db.Uuid
  warehouse       Warehouse?         @relation(fields: [warehouseId], references: [id])
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  creditNoteItems    CreditNoteItem[]

  @@unique([tenantId, barcode])
  @@index([tenantId, barcode])
  @@index([tenantId, id])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.Text
  creditLimit Decimal? @default(0) @map("credit_limit") @db.Decimal(12, 2)
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales  Sale[]
  creditNotes CreditNote[]
  accountsReceivable AccountsReceivable[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("customers")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  contact   String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  email     String?  @db.VarChar(255)
  address   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  accountsPayable AccountsPayable[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("suppliers")
}

model Sale {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  customerId     String?  @map("customer_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  subtotal       Decimal  @db.Decimal(12, 2)
  tax            Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  paymentMethod  String   @default("cash") @map("payment_method") @db.VarChar(50)
  status         String   @default("completed") @db.VarChar(50)
  isOffline      Boolean  @default(false) @map("is_offline")
  offlineId      String?  @map("offline_id") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       SaleItem[]
  creditNotes CreditNote[]
  accountsReceivable AccountsReceivable[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  saleId    String  @map("sale_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  cost      Decimal @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([tenantId, id])
  @@map("sale_items")
}

model PurchaseOrder {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  supplierId    String?  @map("supplier_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  status        String   @default("pending") @db.VarChar(50)
  total         Decimal  @default(0) @db.Decimal(12, 2)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(uuid()) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  purchaseOrderId  String  @map("purchase_order_id") @db.Uuid
  productId        String  @map("product_id") @db.Uuid
  quantity         Int
  cost             Decimal @db.Decimal(12, 2)
  subtotal         Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([tenantId, id])
  @@map("purchase_order_items")
}

model InventoryMovement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  type      String   @db.VarChar(50)
  quantity  Int
  reference String?  @db.VarChar(255)
  notes     String?  @db.Text
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("inventory_movements")
}

model AccountsPayable {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  supplierId      String   @map("supplier_id") @db.Uuid
  purchaseOrderId String?  @map("purchase_order_id") @db.Uuid
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  pendingAmount   Decimal  @map("pending_amount") @db.Decimal(12, 2)
  dueDate         DateTime @map("due_date") @db.Date
  status          String   @default("pending") @db.VarChar(50)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier         @relation(fields: [supplierId], references: [id])
  payments PayablePayment[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@map("accounts_payable")
}

model PayablePayment {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  accountPayableId  String   @map("account_payable_id") @db.Uuid
  amount            Decimal  @db.Decimal(12, 2)
  paymentMethod     String   @default("cash") @map("payment_method") @db.VarChar(50)
  notes             String?  @db.Text
  paidAt            DateTime @map("paid_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at")

  accountPayable AccountsPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountPayableId])
  @@map("payable_payments")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  description   String   @db.VarChar(255)
  amount        Decimal  @db.Decimal(12, 2)
  category      String   @db.VarChar(100)
  paymentMethod String   @default("cash") @map("payment_method") @db.VarChar(50)
  notes         String?  @db.Text
  registeredBy  String   @map("registered_by") @db.Uuid
  expenseDate   DateTime @map("expense_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, expenseDate])
  @@index([tenantId, category])
  @@map("expenses")
}

model CreditNote {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  saleId        String?  @map("sale_id") @db.Uuid
  customerId    String?  @map("customer_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  reason        String   @db.Text
  total         Decimal  @db.Decimal(12, 2)
  status        String   @default("active") @db.VarChar(50)
  refundMethod  String   @default("credit") @map("refund_method") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sale     Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  items    CreditNoteItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("credit_notes")
}

model CreditNoteItem {
  id             String  @id @default(uuid()) @db.Uuid
  creditNoteId   String  @map("credit_note_id") @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  quantity       Int
  price          Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([creditNoteId])
  @@map("credit_note_items")
}

// ── Social Module ────────────────────────────────────────────────────────────

model SocialProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  displayName String   @map("display_name") @db.VarChar(100)
  bio         String?  @db.Text
  avatarUrl   String?  @map("avatar_url") @db.Text
  coverUrl    String?  @map("cover_url") @db.Text
  location    String?  @db.VarChar(100)
  website     String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("social_profiles")
}

model SocialPost {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  images    String[] @default([]) @db.Text
  videos    String[] @default([]) @db.Text
  tags      String[] @default([]) @db.VarChar(100)
  isPinned  Boolean  @default(false) @map("is_pinned")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  SocialComment[]
  reactions SocialReaction[]

  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("social_posts")
}

model SocialCatalog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  coverImage  String?  @map("cover_image") @db.Text
  category    String?  @db.VarChar(100)
  isPublic    Boolean  @default(true) @map("is_public")
  status      String   @default("draft") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at") @db.Timestamptz

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    SocialCatalogItem[]
  comments SocialComment[]
  reactions SocialReaction[]

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, status])
  @@map("social_catalogs")
}

model SocialCatalogItem {
  id        String  @id @default(uuid()) @db.Uuid
  catalogId String  @map("catalog_id") @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  name      String  @db.VarChar(255)
  description String? @db.Text
  price     Decimal @default(0) @db.Decimal(12, 2)
  imageUrl  String? @map("image_url") @db.Text
  category  String? @db.VarChar(100)
  link      String? @db.VarChar(500)
  sortOrder Int     @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  catalog SocialCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([tenantId])
  @@map("social_catalog_items")
}

model SocialComment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String?  @map("post_id") @db.Uuid
  catalogId String?  @map("catalog_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  content   String   @db.Text
  images    String[] @default([]) @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     SocialPost?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  catalog  SocialCatalog?    @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  parent   SocialComment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  SocialComment[]   @relation("CommentReplies")
  reactions SocialReaction[]

  @@index([postId])
  @@index([catalogId])
  @@index([userId])
  @@index([parentId])
  @@index([tenantId])
  @@map("social_comments")
}

model SocialReaction {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String?  @map("post_id") @db.Uuid
  commentId String?  @map("comment_id") @db.Uuid
  catalogId String?  @map("catalog_id") @db.Uuid
  type      String   @default("like") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    SocialPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment SocialComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  catalog SocialCatalog? @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, postId, commentId, catalogId])
  @@index([postId])
  @@index([commentId])
  @@index([catalogId])
  @@index([userId])
  @@map("social_reactions")
}

model SocialFollow {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  followerUserId String   @map("follower_user_id") @db.Uuid
  followedUserId String   @map("followed_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  followerUser  User   @relation("FollowerUsers", fields: [followerUserId], references: [id], onDelete: Cascade)
  followedUser  User   @relation("FollowedUsers", fields: [followedUserId], references: [id], onDelete: Cascade)
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, followerUserId, followedUserId])
  @@index([followerUserId])
  @@index([followedUserId])
  @@map("social_follows")
}

model SocialNotification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  fromUserId String  @map("from_user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String?  @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation("NotificationForUser", fields: [userId], references: [id], onDelete: Cascade)
  fromUser User   @relation("NotificationFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId, createdAt])
  @@map("social_notifications")
}

model SocialThread {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title     String?  @db.VarChar(255)
  isGroup   Boolean  @default(false) @map("is_group")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members     SocialThreadMember[]
  messages    SocialMessage[]

  @@index([tenantId, updatedAt])
  @@map("social_threads")
}

model SocialThreadMember {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  lastReadAt DateTime? @map("last_read_at") @db.Timestamptz
  joinedAt  DateTime @default(now()) @map("joined_at")

  thread SocialThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
  @@map("social_thread_members")
}

model SocialMessage {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  content   String   @db.Text
  images    String[] @default([]) @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at")

  thread SocialThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User         @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId])
  @@map("social_messages")
}

model CalendarEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  startDate   DateTime @map("start_date") @db.Timestamptz
  endDate     DateTime? @map("end_date") @db.Timestamptz
  allDay      Boolean  @default(false) @map("all_day")
  color       String?  @db.VarChar(7)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, startDate])
  @@map("events")
}

model AccountsReceivable {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  saleId          String?  @map("sale_id") @db.Uuid
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  pendingAmount   Decimal  @map("pending_amount") @db.Decimal(12, 2)
  dueDate         DateTime @map("due_date") @db.Date
  status          String   @default("pending") @db.VarChar(50)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer            @relation(fields: [customerId], references: [id])
  sale     Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)
  payments ReceivablePayment[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@map("accounts_receivable")
}

model ReceivablePayment {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  accountReceivableId String   @map("account_receivable_id") @db.Uuid
  amount              Decimal  @db.Decimal(12, 2)
  paymentMethod       String   @default("cash") @map("payment_method") @db.VarChar(50)
  notes               String?  @db.Text
  paidAt              DateTime @map("paid_at") @db.Timestamptz
  createdAt           DateTime @default(now()) @map("created_at")

  accountReceivable AccountsReceivable @relation(fields: [accountReceivableId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountReceivableId])
  @@map("receivable_payments")
}

model CashSession {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  openingBalance  Decimal   @map("opening_balance") @db.Decimal(12, 2)
  closingBalance  Decimal?  @map("closing_balance") @db.Decimal(12, 2)
  actualBalance   Decimal?  @map("actual_balance") @db.Decimal(12, 2)
  difference      Decimal?  @db.Decimal(12, 2)
  status          String    @default("open") @db.VarChar(20)
  openedAt        DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt        DateTime? @map("closed_at") @db.Timestamptz
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions    CashTransaction[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("cash_sessions")
}

model CashTransaction {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  sessionId     String   @map("session_id") @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  type          String   @db.VarChar(20)
  description   String   @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")

  session       CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@map("cash_transactions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(512)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

